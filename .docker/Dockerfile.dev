# Hugo Studio — dev/build image
# Pinned to bookworm so libwebkit2gtk-4.1 (Tauri 2 requirement) is available in apt.
# Rust >= 1.85 is required because tauri 2 transitive deps (zbus_names ≥ 4.3) use edition2024.
FROM rust:1-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# Tauri 2 Linux deps (see https://v2.tauri.app/start/prerequisites/#linux)
# + tooling we need for scaffolding and CI parity.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        file \
        git \
        gnupg \
        jq \
        libayatana-appindicator3-dev \
        libgtk-3-dev \
        libjavascriptcoregtk-4.1-dev \
        librsvg2-dev \
        libsoup-3.0-dev \
        libssl-dev \
        libwebkit2gtk-4.1-dev \
        libxdo-dev \
        pkg-config \
        wget \
        xvfb \
    && rm -rf /var/lib/apt/lists/*

# Node 20 (Tauri 2 + Vite require >= 18; LTS is the safe pick).
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g npm@10

# Add clippy + rustfmt (the base image ships only rustc/cargo/std).
RUN rustup component add clippy rustfmt

# Hugo extended — needed by the preview module's spawn tests and for any
# manual "tauri dev" run inside the container. Pinned to a recent extended
# release. End users supply their own hugo on PATH (or HUGO_STUDIO_HUGO_PATH).
ARG HUGO_VERSION=0.139.4
RUN curl -fsSL "https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz" \
        -o /tmp/hugo.tgz \
    && tar -xzf /tmp/hugo.tgz -C /tmp hugo \
    && install -m 0755 /tmp/hugo /usr/local/bin/hugo \
    && rm -rf /tmp/hugo /tmp/hugo.tgz \
    && hugo version

# Speed up cargo by using the sparse registry protocol.
ENV CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse \
    CARGO_TERM_COLOR=always \
    RUST_BACKTRACE=1

# The base rust image puts cargo on PATH via ENV, but `bash -l` reloads
# /etc/profile and drops it. Re-add via profile.d so login shells see it too.
RUN printf 'export PATH=/usr/local/cargo/bin:$PATH\n' > /etc/profile.d/10-cargo.sh \
    && chmod +x /etc/profile.d/10-cargo.sh

WORKDIR /workspace

CMD ["bash"]
